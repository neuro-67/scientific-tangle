# Backend
BACKEND_PORT=8000

# Frontend (Vite dev server)
FRONTEND_PORT=5173

# Postgres
POSTGRES_USER=st
POSTGRES_PASSWORD=st_password
POSTGRES_DB=scientific_tangle
POSTGRES_PORT=5432

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DOCUMENTS_BUCKET=documents

# Redis (arq job queue)
REDIS_PORT=6379

# LLM (Yandex AI Studio)
LLM_API_KEY=
LLM_MODEL=

# LLM fallback (RouterAI, OpenAI-compatible) -- used automatically by
# nlp/query/config.py when set, in preference to Yandex
ROUTERAI_API_KEY=
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_MODEL=google/gemini-3.1-flash-lite

# Auth
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# Admin seed (used by `python -m app.cli.seed_admin`)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_FULL_NAME=Platform Administrator
